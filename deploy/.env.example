# ─────────────────────────────────────────────────────────────
# Gateway (ContextForge) — required
# ─────────────────────────────────────────────────────────────
# Rotate before prod. Must be >= 32 bytes.
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_AUDIENCE=mcpgateway-api
JWT_ISSUER=mcpgateway

# Admin used by the bootstrap job and Admin UI login.
# Seed happens once on first migration — rotating this later needs a DB reset
# (`make clean`) or a manual password reset via the Admin UI.
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=changeme

# Postgres password used by the bundled DB.
POSTGRES_PASSWORD=change-me

# Public URL (nginx front). Update for prod behind your own ingress.
APP_DOMAIN=http://localhost:8080
NGINX_PORT=8080

# Keycloak is disabled by default. Do not add --profile sso.
SSO_ENABLED=false
SSO_KEYCLOAK_ENABLED=false

# Use the released ContextForge image; we don't build it locally (Containerfile.lite
# pulls a linux/s390x wheels stage from GHCR that needs auth).
IMAGE_LOCAL=ghcr.io/ibm/mcp-context-forge:v1.0.4

# ─────────────────────────────────────────────────────────────
# Tableau (used by Tableau MCP + dashboard-context)
# ─────────────────────────────────────────────────────────────
TABLEAU_SERVER=https://your-tableau-server.example.com
TABLEAU_SITE_NAME=
TABLEAU_PAT_NAME=change-me
TABLEAU_PAT_VALUE=change-me
TABLEAU_API_VERSION=3.22

# Optional Tableau MCP knobs (blank = defaults).
TABLEAU_MCP_REF=v2.22.0
TABLEAU_LOG_LEVEL=info
TABLEAU_INCLUDE_TOOLS=
TABLEAU_EXCLUDE_TOOLS=
TABLEAU_MAX_RESULT_LIMIT=
TABLEAU_DATASOURCE_CREDENTIALS=
